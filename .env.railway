# GlucoEase Backend - Railway 部署配置
# ⚠️ 注意：此文件不包含真实密钥，请在 Railway 控制台设置环境变量

# 应用配置
APP_NAME=GlucoEase
APP_VERSION=1.0.0
DEBUG=false

# 数据库配置 (Supabase PostgreSQL)
# 请在 Railway Variables 中设置: DATABASE_URL

# Redis 配置 (Upstash)
# 请在 Railway Variables 中设置: REDIS_URL

# JWT 配置
# 请在 Railway Variables 中设置: SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# DeepSeek API (必需)
# 请在 Railway Variables 中设置: DEEPSEEK_API_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 火山引擎语音服务 (必需)
# 请在 Railway Variables 中设置: VOLCANO_APP_ID 和 VOLCANO_ACCESS_TOKEN
